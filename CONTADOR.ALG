Algoritmo "contador"
// Disciplina   : Algoritmos
// Professor   : Agnaldo Carneiro 
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Giovanna Karolina Neres da Costa(a)
// Data atual  : 26/03/2026
Var
// Seçăo de Declaraçőes das variáveis 
contador: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
contador <-1
enquanto (contador <=5) faca
escreval (contador)
contador<-contador+1
fimenquanto

Fimalgoritmo